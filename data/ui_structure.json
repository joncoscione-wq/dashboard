      "elementos": ["imagen logo (procesada canvas)", "divisor vertical 1px rgba(255,255,255,.18)", "texto 'Contexto Investments' Poppins 22px bold + subtítulo 'RECURSOS HUMANOS' DM Sans 13px uppercase letter-spacing 2.8px"]
